@model IEnumerable<EcommerceMVC.Models.Produto>

@{
    ViewData["Title"] = "Manga&Lamen Homepage";
}

<style>
    /* SEÇÃO DE MANGÁS */
    .mangas {
        padding: 20px;
    }

    .card {
        background-color: white;
        padding: 10px;
    }

        .card img {
            width: 100%;
            aspect-ratio: 2 / 3;
            object-fit: cover;
            border-radius: 5px;
        }

            .card img:hover {
                transform: scale(1.05);
                transition: 0.3s;
            }

    /* PERSONAGENS */
    .personagens {
        background-color: #222;
        padding: 20px;
        display: flex;
        justify-content: space-around;
    }

        .personagens img {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            object-fit: cover;
        }

    /* DESTAQUES */
    .destaques {
        padding: 20px;
    }
</style>

<section class="mangas">
    <div class="text-center">
        <div class="container mt-4">
            <h2 class="mb-4">Produtos em Destaque</h2>
            <div class="row">
                @foreach (var item in Model)
                {
                    <div class="col-md-4 mb-3">
                        <div class="card shadow-sm">
                            <img src="/img/@item.Imagem" class="card-img-top" alt="@item.Nome">
                            <div class="card-body">
                                <h5 class="card-title">@item.Nome</h5>
                                <p class="card-text text-muted">@item.Descricao</p>
                                <h4 class="text-primary">R$ @item.Preco.ToString("N2")</h4>
                                <a href="#" class="btn btn-success w-100">Comprar</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<section class="personagens">
    <img src="char1.jpg">
    <img src="char2.jpg">
    <img src="char3.jpg">
    <img src="char4.jpg">
</section>

<section class="destaques">

</section>